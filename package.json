    "test:latency": "tsc -p tsconfig.main.json && node scripts/bench-view-query.mjs --check --current-only db_rows_stress db_rows_2k db_rows_20k && node scripts/bench-csv-read-latency.mjs --check",
    "test:page-open-latency": "tsc -p tsconfig.main.json && node scripts/bench-page-open-latency.mjs --check",
    "test:search-latency": "tsc -p tsconfig.main.json && node scripts/bench-search-latency.mjs --check",
    "test:startup-latency": "tsc -p tsconfig.main.json && node scripts/bench-startup-latency.mjs --check",
    "test:cell-edit-latency": "tsc -p tsconfig.main.json && node scripts/bench-cell-edit-latency.mjs --check",
    "test:csv-read-latency": "tsc -p tsconfig.main.json && node scripts/bench-csv-read-latency.mjs --check",
    "test:rollup-latency": "tsc -p tsconfig.main.json && node scripts/bench-rollup-latency.mjs --check",
    "benchmark:latency": "node scripts/bench-view-query.mjs --current-only",
    "benchmark:page-open-latency": "tsc -p tsconfig.main.json && node scripts/bench-page-open-latency.mjs",
    "benchmark:search-latency": "tsc -p tsconfig.main.json && node scripts/bench-search-latency.mjs",
