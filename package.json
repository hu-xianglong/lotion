    "test:file-boundary": "node scripts/check-file-service-boundary.mjs",
    "test:customer-api": "tsc -p tsconfig.main.json && node --test test/customer-api.test.mjs",
    "test:integration": "tsc -p tsconfig.main.json && node --test test/integration/notion-import-workflow.test.mjs",
    "test:coverage": "node scripts/check-package-coverage.mjs",
