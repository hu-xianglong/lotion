{
  "name": "lotion",
  "version": "0.1.0",
  "private": true,
  "description": "An LLM-first local Notion.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hu-xianglong/lotion.git"
  },
