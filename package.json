    "test:links": "node scripts/validate-links.mjs",
    "test:hierarchy": "node scripts/validate-hierarchy.mjs",
    "test:ui-regression": "tsc -p tsconfig.main.json && node scripts/test-renderer-components.mjs && LOTION_UI_SUITE_FILTER=notion-import,row-page-navigation,row-page-property-visual,source-attachments,markdown-preview-ui,smoke-search-ui.mjs,search-title,search-ai,embedded-view,settings-center,plugin-manager,llm-chat,advanced-search,url-field,white-theme,design-system,image-lightbox,database-created-views,page-backlinks,page-secondary,editor-regression,editor-link-click,editor-scroll,smoke-navigation-anchor-ui.mjs node scripts/smoke-ui-suite.mjs",
