      "types": "./src/main/customer-api.ts",
      "default": "./dist-electron/main/customer-api.js"
    },
    "./customer-api-contract": {
      "types": "./src/shared/customer-api-contract.ts",
      "default": "./dist-electron/shared/customer-api-contract.js"
    },
    "./plugin-api": {
      "types": "./src/shared/plugin-api.ts",
      "default": "./dist-electron/shared/plugin-api.js"
    },
    "./plugin-react": {
      "types": "./src/shared/plugin-react.ts",
      "default": "./dist-electron/shared/plugin-react.js"
    }
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "demo:reset": "node scripts/reset-demo-space.mjs",
    "test": "npm run test:fast",
