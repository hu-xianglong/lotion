    "smoke:search-title-ui": "tsc -p tsconfig.main.json && node scripts/smoke-search-title-ui.mjs",
    "smoke:search-ai-ui": "tsc -p tsconfig.main.json && node scripts/smoke-search-ai-ui.mjs",
    "benchmark:search-ui": "tsc -p tsconfig.main.json && node scripts/smoke-search-ui.mjs",
    "smoke:embedded-view-ui": "tsc -p tsconfig.main.json && node scripts/smoke-embedded-view-ui.mjs",
