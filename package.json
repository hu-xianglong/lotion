    "smoke:plugin-manager-ui": "tsc -p tsconfig.main.json && node scripts/smoke-plugin-manager-ui.mjs",
    "smoke:llm-chat-ui": "tsc -p tsconfig.main.json && node scripts/smoke-llm-chat-ui.mjs",
    "smoke:advanced-search-ui": "tsc -p tsconfig.main.json && node scripts/smoke-advanced-search-ui.mjs",
    "smoke:github-backup-ui": "tsc -p tsconfig.main.json && node scripts/smoke-github-backup-ui.mjs",
    "smoke:url-field-ui": "tsc -p tsconfig.main.json && node scripts/smoke-url-field-ui.mjs",
    "smoke:white-theme-ui": "tsc -p tsconfig.main.json && node scripts/smoke-white-theme-ui.mjs",
    "smoke:design-system-ui": "tsc -p tsconfig.main.json && node scripts/smoke-design-system-ui.mjs",
    "smoke:image-lightbox-ui": "tsc -p tsconfig.main.json && node scripts/smoke-image-lightbox-ui.mjs",
    "smoke:window-popout-ui": "tsc -p tsconfig.main.json && node scripts/smoke-window-popout-ui.mjs",
    "smoke:database-template-ui": "tsc -p tsconfig.main.json && node scripts/smoke-database-template-ui.mjs",
    "smoke:database-created-views-ui": "tsc -p tsconfig.main.json && node scripts/smoke-database-created-views-ui.mjs",
    "test:fixtures:deep": "node scripts/validate-demo-space.mjs --deep",
    "test:full": "tsc -p tsconfig.main.json && node scripts/test-notion-html-converter.mjs && node scripts/test-formula-engine.mjs && npm run test:links && npm run test:fixtures:deep",
    "test:notion-html": "tsc -p tsconfig.main.json && node scripts/test-notion-html-converter.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "app:commit": "node scripts/build-commit-app.mjs",
    "build": "tsc -p tsconfig.main.json && vite build",
    "release:test": "node scripts/release-test.mjs",
    "release:test:prechecked": "node scripts/release-test.mjs --prechecked",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
